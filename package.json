{
  "name": "financial-monitoring-platform",
  "version": "1.0.0",
  "description": "A personalized stock market dashboard that enables users to follow stocks, build a watchlist, and receive smart in-app alerts.",
  "main": "index.js",
  "private": true,
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "frontend:dev": "npm run dev --prefix frontend",
    "backend:dev": "npm run dev --prefix backend",
    "dev": "npm run db:up && concurrently \"npm run backend:dev\" \"npm run frontend:dev\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dorhaboosha/Financial-Monitoring-Platform.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/dorhaboosha/Financial-Monitoring-Platform/issues"
  },
  "homepage": "https://github.com/dorhaboosha/Financial-Monitoring-Platform#readme",
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
