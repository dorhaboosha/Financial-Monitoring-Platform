# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://app_user:app_password@localhost:5434/financial_monitoring_platform"

# Port the backend server will listen on.
PORT=5000

# URL of the frontend app (used for CORS).
# In development: http://localhost:5173
# In production: your deployed frontend URL (e.g. https://your-app.onrender.com)
CLIENT_URL=http://localhost:5173

# Name of the cookie used to identify anonymous sessions.
ANONYMOUS_COOKIE_NAME=anonymous_id

# Node environment. Use "production" in deployed environments.
NODE_ENV=development

# Finnhub API key. Get yours at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here
